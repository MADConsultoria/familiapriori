{
  "name": "plataforma-indicacao",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "fix:encoding": "node scripts/fix-encoding.mjs",
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently -k -n FRONT,BACK -c green,cyan \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build:frontend",
    "build:frontend": "vite build",
    "preview:frontend": "vite preview",
    "start:backend": "npm --prefix backend start",
    "start": "npm run start:backend"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0"
  }
}
